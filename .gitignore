# ============================================================
# .gitignore for GitDemo Project
# Lines starting with # are comments — Git ignores them
# ============================================================

# ============================================================
# Ignore ALL files with .log extension
# * is a wildcard — matches any filename
# *.log matches: app.log, error.log, debug.log etc.
# ============================================================
*.log

# ============================================================
# Ignore the entire logs folder and everything inside it
# Trailing / means it's a directory
# logs/ ignores the folder AND all files inside recursively
# ============================================================
logs/

# ============================================================
# Other commonly ignored files (good practice to include)
# ============================================================

# Maven build output
target/

# Compiled Java class files
*.class

# Eclipse IDE files
.classpath
.project
.settings/

# VS Code files
.vscode/

# Environment variables / secrets
.env

# OS generated files
.DS_Store
Thumbs.db